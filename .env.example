# Dahila Crochet — Environment variables
# Copy this file to .env.local and fill in your credentials.

# Supabase project — get these from app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# Public site URL — used for canonical URLs, sitemap, OG tags.
# Defaults to https://dahila.uy if not set.
NEXT_PUBLIC_SITE_URL=https://dahila.uy

# ── Email transaccional (Resend) ────────────────────────────────
# Sin estas variables el envío de emails se desactiva solo (no rompe nada).
# Resend (https://resend.com): 3.000 emails/mes gratis, mejor DX con Next.js.
# Para enviar a la dueña y a clientes hay que verificar un dominio propio en
# Resend (cargando los registros DNS donde administres el dominio, ej. NetUY) y
# cambiar EMAIL_FROM a ese dominio. Hasta entonces usá "onboarding@resend.dev"
# (modo prueba: Resend solo entrega al mail dueño de la cuenta).
# Cuando tengas el dominio, el ÚNICO cambio de app es EMAIL_FROM + redeploy.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
# EMAIL_FROM=Dahila Crochet <hola@tu-dominio>
# OWNER_NOTIFICATION_EMAIL=floralcrochet12@gmail.com

# ── Resumen diario (cron protegido en /api/cron/daily-summary) ──
# Secreto para autorizar el cron. Generá uno con:  openssl rand -hex 24
# CRON_SECRET=pon-un-secreto-largo-aleatorio

# ── Marketing / automatizaciones (FUTURO — Brevo) ───────────────
# Inerte hasta que exista. Newsletter, campañas y recuperación de carrito.
# BREVO_API_KEY=xkeysib-xxxxxxxx
